<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
    <h1 class="col-6 offset-3">Login for Wanderlust</h1>
    <div class="col-6 offset-3">
        <form action="/login" method="POST" class="needs-validation" novalidate>
            
            <div class="mb-3">
                <label for="username" class="form-label">Username</label>
                <input name="username" id="username" type="text" class="form-control" required>  <!-- ✅ Fix 1: capital U removed -->
                <div class="valid-feedback">Looks good!</div>  <!-- ✅ Fix 2: "feeedback" → "feedback" -->
            </div>

            <div class="mb-3">
                <label for="password" class="form-label">Password</label>
                <input name="password" id="password" type="password" class="form-control" required>  <!-- ✅ Fix 4: type="password" to hide input -->
            </div>

            <button class="btn btn-success">login</button>
        </form>
    </div>
</div>

